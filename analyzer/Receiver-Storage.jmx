        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="HTTP Request First Batch Event">
          <stringProp name="TestPlan.comments">Performance metrics</stringProp>
          <stringProp name="HTTPSampler.domain">localhost</stringProp>
          <stringProp name="HTTPSampler.port">8080</stringProp>
          <stringProp name="HTTPSampler.path">/monitoring/performance</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;server_id&quot;: &quot;server-${__Random(1,999,)}&quot;,&#xd;
  &quot;reporting_timestamp&quot;: &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;,)}&quot;,&#xd;
  &quot;metrics&quot;: [&#xd;
    {&#xd;
      &quot;cpu&quot;: ${__Random(10,95,)}.${__Random(0,9,)},&#xd;
      &quot;memory&quot;: ${__Random(20,90,)}.${__Random(0,9,)},&#xd;
      &quot;disk_io&quot;: ${__Random(50,500,)}.${__Random(0,9,)},&#xd;
      &quot;recorded_timestamp&quot;: &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;,)}&quot;&#xd;
    },&#xd;
    {&#xd;
      &quot;cpu&quot;: ${__Random(15,98,)}.${__Random(0,9,)},&#xd;
      &quot;memory&quot;: ${__Random(25,95,)}.${__Random(0,9,)},&#xd;
      &quot;disk_io&quot;: ${__Random(60,600,)}.${__Random(0,9,)},&#xd;
      &quot;recorded_timestamp&quot;: &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;,)}&quot;&#xd;
    },&#xd;
    {&#xd;
      &quot;cpu&quot;: ${__Random(12,92,)}.${__Random(0,9,)},&#xd;
      &quot;memory&quot;: ${__Random(18,88,)}.${__Random(0,9,)},&#xd;
      &quot;disk_io&quot;: ${__Random(45,550,)}.${__Random(0,9,)},&#xd;
      &quot;recorded_timestamp&quot;: &quot;${__time(yyyy-MM-dd&apos;T&apos;HH:mm:ss&apos;Z&apos;,)}&quot;&#xd;
    }&#xd;
  ]&#xd;
}&#xd;
</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
