openapi: 3.0.3
info:
  description: This API receives system monitoring data from enterprise servers to track performance and errors
  version: "1.0.0"
  title: Enterprise System Monitoring API
  contact:
    email: chelsie.lele@example.com
paths:
  /monitoring/performance:

  # /monitoring/performance
  # ─ PerformanceMetricsBatch
 # │   # ├─ server_id (UUID)
  #│    # ├─ reporting_timestamp (datetime)
  #│    # └─ metrics (array of PerformanceMetric)
  #│         # ├─ cpu (number)
  #│         # ├─ memory (number)
 # │         # ├─ disk_io (number)
  #│        #  └─ recorded_timestamp (datetime)

    post:
      summary: Reports a batch of system performance metrics
      operationId: app.report_performance_metrics
      # What does operationId: app.report_performance_metrics mean?
      # app = your Python file (app.py)
      # report_performance_metrics = the function name in that file
      # When someone POSTs to /monitoring/performance, Python will call app.report_performance_metrics()
      description: Adds a batch of CPU, memory, and disk I/O readings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PerformanceMetricsBatch'
      responses:
        '201':
          description: batch successfully received
        '400':
          description: 'invalid input, object invalid'

  /monitoring/errors:
    post:
      summary: Reports a batch of server error metrics
      operationId: app.report_error_metrics
      description: Adds a batch of error codes, severity levels, and average response times
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ErrorMetricsBatch'
      responses:
        '201':
          description: batch successfully received
        '400':
          description: 'invalid input, object invalid'

components:
  schemas:
    PerformanceMetricsBatch:
      required:
      - server_id
      - reporting_timestamp
      - metrics
      properties:
        server_id:
          type: string
          format: uuid
          example: "d290f1ee-6c54-4b01-90e6-d701748f0851"
        reporting_timestamp:
          type: string
          format: date-time
          example: "2026-01-14T10:00:00Z"
        metrics:
          type: array
          items:
            $ref: '#/components/schemas/PerformanceMetric'
      type: object

    PerformanceMetric:
      required:
        - cpu
        - memory
        - disk_io
      properties:
        cpu:
          type: number
          example: 72.5
        memory:
          type: number
          example: 64.2
        disk_io:
          type: number
          example: 120.5
      type: object

    ErrorMetricsBatch:
      required:
      - server_id
      - reporting_timestamp
      - errors
      properties:
        server_id:
          type: string
          format: uuid
          example: "a12f3c9e-1b23-4c56-9d78-123456789abc"
        reporting_timestamp:
          type: string
          format: date-time
          example: "2026-01-14T10:00:00Z"
        errors:
          type: array
          items:
            $ref: '#/components/schemas/ErrorMetric'
      type: object

    ErrorMetric:
      required:
        - error_code
        - severity_level
        - avg_response_time
        - error_message
      properties:
        error_code:
          type: string
          example: 500
        severity_level:
          type: integer
          description: 1=Low, 5=Critical
          example: 4
        avg_response_time:
          type: number
          description: average response time in milliseconds
          example: 1200.5
        error_message:      
          type: string      
          maxLength: 500  
          example: "Database connection timeout after 30s"
      type: object
